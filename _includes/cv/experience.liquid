{% comment %}
  Unified work/experience entry renderer — stacked (non-split) layout
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      {% capture position_title %}
        {% if entry.position %}{{ entry.position }}{% endif %}
      {% endcapture %}

      {% capture company_name %}
        {% if entry.name %}{{ entry.name }}{% elsif entry.company %}{{ entry.company }}{% elsif entry.organization %}{{ entry.organization }}{% endif %}
      {% endcapture %}

      {% capture start_date %}
        {% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}
      {% endcapture %}
      {% capture end_date %}
        {% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}
      {% endcapture %}

      {% if start_date != '' %}
        {% assign startDate = start_date | strip | split: '-' | first %}
        {% assign endDate = end_date | strip | split: '-' | first | default: 'Present' %}
        {% assign date = startDate | append: ' - ' | append: endDate %}
      {% else %}
        {% assign date = '' %}
      {% endif %}

      <div class="d-flex align-items-baseline flex-wrap mb-1">
        {% if entry.url %}
          <h6 class="title font-weight-bold mr-2 mb-0">
            <a href="{{ entry.url }}">{{ position_title }}</a>
          </h6>
        {% elsif position_title != '' %}
          <h6 class="title font-weight-bold mr-2 mb-0">{{ position_title }}</h6>
        {% endif %}

        {% if company_name != '' %}
          <span class="mr-2" style="font-size: 0.95rem">@ {{ company_name }}</span>
        {% endif %}

        {% if date != '' %}
          <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle">{{ date }}</span>
        {% endif %}
      </div>

      {% capture location %}
        {% if entry.location %}{{ entry.location | strip }}{% endif %}
      {% endcapture %}
      {% if location != '' %}
        <p class="location mb-1">
          <i class="fa-solid fa-location-dot iconlocation"></i>
          {{ location }}
        </p>
      {% endif %}

      {% if entry.summary %}
        <p class="mb-1" style="font-size: 0.95rem; font-style: italic">
          {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
        </p>
      {% endif %}

      {% if entry.highlights %}
        <ul class="items">
          {% for item in entry.highlights %}
            <li>
              <span class="item">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </li>
  {% endfor %}
</ul>
