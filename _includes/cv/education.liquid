{% comment %}
  Unified education entry renderer — stacked layout, school name first
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      {% capture study_type %}
        {% if entry.studyType %}{{ entry.studyType }}{% elsif entry.degree %}{{ entry.degree }}{% endif %}
      {% endcapture %}

      {% capture start_date %}
        {% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}
      {% endcapture %}
      {% capture end_date %}
        {% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}
      {% endcapture %}

      {% if start_date != '' %}
        {% assign startDate = start_date | strip | split: '-' | first %}
        {% assign endDate = end_date | strip | split: '-' | first | default: 'Present' %}
        {% assign date = startDate | append: ' - ' | append: endDate %}
      {% else %}
        {% assign date = '' %}
      {% endif %}

      <div class="d-flex align-items-baseline flex-wrap mb-1">
        {% if entry.url and entry.institution %}
          <h6 class="title font-weight-bold mr-2 mb-0">
            <a href="{{ entry.url }}">{{ entry.institution }}</a>
          </h6>
        {% elsif entry.institution %}
          <h6 class="title font-weight-bold mr-2 mb-0">{{ entry.institution }}</h6>
        {% endif %}

        {% if study_type != '' %}
          <span class="mr-2" style="font-size: 0.95rem">- {{ study_type }}</span>
        {% endif %}

        {% if date != '' %}
          <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle">{{ date }}</span>
        {% endif %}
      </div>

      {% if entry.area %}
        <p class="mb-1" style="font-size: 0.95rem; font-style: italic">{{ entry.area }}</p>
      {% endif %}

      {% if entry.courses or entry.highlights %}
        <ul class="items">
          {% for item in entry.courses %}
            <li>
              <span class="item">{{ item }}</span>
            </li>
          {% endfor %}
          {% for item in entry.highlights %}
            <li>
              <span class="item">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </li>
  {% endfor %}
</ul>
